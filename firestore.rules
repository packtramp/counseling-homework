rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Counselees can read their counselor's profile (for contact info)
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == userId;
      // Counselors can create/delete profiles for their counselees
      allow create: if request.auth != null && request.resource.data.counselorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.counselorId == request.auth.uid;
      // Allow authenticated users to search for other users (for accountability partners)
      allow read: if request.auth != null;
      // Allow updating accountability arrays by authenticated users (for bidirectional linking)
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['watchingUsers', 'accountabilityPartners', 'accountabilityPartnerUids']);
    }

    // Pending invites - read/delete for authenticated users, write requires inviterUid match
    match /pendingInvites/{emailKey} {
      allow read, delete: if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.inviterUid == request.auth.uid;
    }

    // Partner requests - only target or requester can read; only they can update
    match /partnerRequests/{token} {
      allow read: if request.auth != null &&
        (resource.data.targetUid == request.auth.uid || resource.data.requesterUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.targetUid == request.auth.uid || resource.data.requesterUid == request.auth.uid);
    }

    // Encouragements - cheers, nudges, messages between users
    match /encouragements/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Rate limits - server-side only (admin SDK bypasses rules)
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Counselee email links - counselors can write, anyone can read their own
    match /counseleeLinks/{emailKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Prayer Requests - user owns their own PRs, APs + counselors can read
    match /users/{userId}/prayerRequests/{requestId} {
      // Owner can CRUD their own prayer requests
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // APs can read and update prayerCount (via accountabilityPartnerUids on the PR owner's user doc)
      allow read, update: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.accountabilityPartnerUids;
      // Counselor can read and update prayerCount on their counselee's prayer requests
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(userId)).data.counselorId == request.auth.uid;

      // Prayers subcollection - records of who prayed
      match /prayers/{prayerId} {
        // Owner of the PR can read prayers on their requests
        allow read: if request.auth != null && request.auth.uid == userId;
        // APs can read and write prayers (to record "prayed" clicks)
        allow read, create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.accountabilityPartnerUids;
        // Counselor can read and write prayers
        allow read, create: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(userId)).data.counselorId == request.auth.uid;
      }
    }

    // Counselor data - counselor can access their own counselees
    match /counselors/{counselorId}/counselees/{counseleeId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      // Counselee can read and update their own record (for photo, name, etc.)
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path: counseleeId IS the user uid)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path: look up uid from counselee doc)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Homework - counselor full access, counselee read + update + create + delete
    match /counselors/{counselorId}/counselees/{counseleeId}/homework/{homeworkId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Heart Journals - counselor full access, counselee can create, read, and update own
    match /counselors/{counselorId}/counselees/{counseleeId}/heartJournals/{journalId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Think Lists - counselor full access, counselee can read, create, update, delete
    match /counselors/{counselorId}/counselees/{counseleeId}/thinkLists/{listId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Journals - counselor full access, counselee can read, create, update, delete
    match /counselors/{counselorId}/counselees/{counseleeId}/journals/{journalId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Session Notes - counselor full access, counselee can read and add their own notes
    match /counselors/{counselorId}/counselees/{counseleeId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Activity Log - counselor full access, counselee can read and create
    match /counselors/{counselorId}/counselees/{counseleeId}/activityLog/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == counselorId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counseleeDocId == counseleeId;
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }
  }
}
