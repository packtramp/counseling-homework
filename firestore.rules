rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // C-2: a user may reach a counselee's private content ONLY if that counselee
    // record actually points back at them (record.uid == caller). This does NOT trust
    // the caller's OWN self-set counselorId/counseleeDocId (which they can forge by
    // recreating their profile or planting a counseleeLink) — so both spoof paths are
    // dead. Fails closed if the record or its uid is missing.
    function isTheCounselee(counselorId, counseleeId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.get('uid', '') == request.auth.uid;
    }

    match /users/{userId} {
      // Users can read their own profile; create/delete their own doc
      allow read, create, delete: if request.auth != null && request.auth.uid == userId;
      // Owner can UPDATE their own profile — EXCEPT the fields that grant cross-user data
      // access or elevate role. Those are set only at creation / via the Admin SDK.
      // (C-2: blocks a user from re-pointing counselorId/counseleeDocId at a victim to
      //  read/write/delete the victim's content, and from self-granting isAdmin/role.)
      allow update: if request.auth != null && request.auth.uid == userId &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['counselorId', 'counseleeDocId', 'isAdmin', 'isSuperAdmin', 'role', 'approved']);
      // Counselees can read their counselor's profile (for contact info)
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.counselorId == userId;
      // Counselors can create/delete profiles for their counselees
      allow create: if request.auth != null && request.resource.data.counselorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.counselorId == request.auth.uid;
      // Allow authenticated users to search for other users (for accountability partners)
      // TODO(security H-3): still exposes all profile PII to any account — replace with a
      // minimal directory doc / server search. Deferred; not the content-read breach.
      allow read: if request.auth != null;
      // Bidirectional linking: any authed user may add to a partner's WATCHING/display arrays
      // only. accountabilityPartnerUids (the read-access key) is NO LONGER client-writable
      // across users — it is written server-side after validation (C-1: was self-injectable).
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['watchingUsers', 'accountabilityPartners']);
    }

    // Pending invites - read/delete for authenticated users, write requires inviterUid match
    match /pendingInvites/{emailKey} {
      allow read, delete: if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.inviterUid == request.auth.uid;
    }

    // Partner requests - only target or requester can read; only they can update
    match /partnerRequests/{token} {
      allow read: if request.auth != null &&
        (resource.data.targetUid == request.auth.uid || resource.data.requesterUid == request.auth.uid);
      // Create only a request FROM yourself (M-9: prevents forging a request "from" a victim).
      allow create: if request.auth != null &&
        request.resource.data.requesterUid == request.auth.uid;
      allow update: if request.auth != null &&
        (resource.data.targetUid == request.auth.uid || resource.data.requesterUid == request.auth.uid);
    }

    // Encouragements - cheers, nudges, messages between users
    match /encouragements/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Rate limits - server-side only (admin SDK bypasses rules)
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Account approval tokens - server-side only (admin SDK writes; the one-click Allow
    // link in the admin's email reads/deletes it server-side). Never client-accessible so
    // the token can't be harvested to self-approve.
    match /accountApprovals/{uid} {
      allow read, write: if false;
    }

    // Counselee email links — useAuth auto-provisions a counselee's profile from here at
    // first login (it trusts counselorId/counseleeDocId from this doc). Was world-writable,
    // letting any account repoint a not-yet-activated counselee at themselves and harvest
    // their future journals (provisioning hijack). Lock writes to the OWNING counselor and
    // forbid overwriting a link owned by a different counselor.
    // (H-3: read stays open — enumeration — deferred; reading a link now grants no content
    //  by itself since provisioning can no longer be repointed.)
    match /counseleeLinks/{emailKey} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.counselorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.counselorId == request.auth.uid;
    }

    // Prayer Requests - user owns their own PRs, APs (in sharedWith) + counselors can read
    match /users/{userId}/prayerRequests/{requestId} {
      // Owner can CRUD their own prayer requests
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // APs can read and update prayerCount IFF they are in this PR's sharedWith array.
      // Legacy docs without sharedWith fall back to accountabilityPartnerUids (migration target).
      allow read, update: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.accountabilityPartnerUids &&
        (!('sharedWith' in resource.data) || request.auth.uid in resource.data.sharedWith);
      // Counselor can read and update prayerCount on their counselee's prayer requests (unrestricted)
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(userId)).data.counselorId == request.auth.uid;

      // Prayers subcollection - records of who prayed
      match /prayers/{prayerId} {
        // Owner of the PR can read prayers on their requests
        allow read: if request.auth != null && request.auth.uid == userId;
        // APs can read/create prayers IFF in parent PR's sharedWith (or legacy docs without the field)
        allow read, create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.accountabilityPartnerUids &&
          (!('sharedWith' in get(/databases/$(database)/documents/users/$(userId)/prayerRequests/$(requestId)).data) ||
            request.auth.uid in get(/databases/$(database)/documents/users/$(userId)/prayerRequests/$(requestId)).data.sharedWith);
        // Counselor can read and write prayers (unrestricted)
        allow read, create: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(userId)).data.counselorId == request.auth.uid;
      }
    }

    // Counselor data - counselor can access their own counselees
    match /counselors/{counselorId}/counselees/{counseleeId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      // Counselee can read and update their own record (for photo, name, etc.)
      allow read, update: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path: counseleeId IS the user uid)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path: look up uid from counselee doc)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Homework - counselor full access, counselee read + update + create + delete
    match /counselors/{counselorId}/counselees/{counseleeId}/homework/{homeworkId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update, delete: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Heart Journals - counselor full access, counselee can create, read, and update own
    match /counselors/{counselorId}/counselees/{counseleeId}/heartJournals/{journalId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Think Lists - counselor full access, counselee can read, create, update, delete
    match /counselors/{counselorId}/counselees/{counseleeId}/thinkLists/{listId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update, delete: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Journals - counselor full access, counselee can read, create, update, delete
    match /counselors/{counselorId}/counselees/{counseleeId}/journals/{journalId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create, update, delete: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Session Notes - counselor full access, counselee can read and add their own notes
    match /counselors/{counselorId}/counselees/{counseleeId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, update: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }

    // Activity Log - counselor full access, counselee can read and create
    match /counselors/{counselorId}/counselees/{counseleeId}/activityLog/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      allow read, create: if request.auth != null &&
        isTheCounselee(counselorId, counseleeId);
      // Accountability partners can read (self-counselor path)
      allow read: if request.auth != null &&
        counselorId == counseleeId &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(counseleeId)).data.accountabilityPartnerUids;
      // Accountability partners can read (real counselee path)
      allow read: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(
          get(/databases/$(database)/documents/counselors/$(counselorId)/counselees/$(counseleeId)).data.uid
        )).data.accountabilityPartnerUids;
    }
  }
}
