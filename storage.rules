rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Counselee profile photos: counselees/{counselorId}/{counseleeId}/profile.jpg
    match /counselees/{counselorId}/{counseleeId}/{fileName} {
      // Counselor can upload photos for their counselees
      allow read, write: if request.auth != null && request.auth.uid == counselorId;

      // Counselee can upload their own photo (they have counselorId in their profile)
      // Note: We can't check Firestore from Storage rules, so we allow any authenticated user
      // who knows the correct path. The app logic ensures only the right user can access.
      allow read, write: if request.auth != null;
    }

    // Counselor profile photos: counselors/{counselorId}/profile.jpg
    match /counselors/{counselorId}/{fileName} {
      // Counselor can read/write their own profile photo
      allow read, write: if request.auth != null && request.auth.uid == counselorId;
      // Counselees can read their counselor's photo
      allow read: if request.auth != null;
    }

    // Feedback screenshots: feedback/{uid}/{fileName}
    // Authenticated users can upload to their own folder, anyone can read (for GitHub issue embeds)
    match /feedback/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read: if true;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
